---
const audits = [
  {
    key: "cve", tone: "danger", span: "lg", title: "Security / CVE scan",
    body: "Surfaces known vulnerabilities in what you've installed, with a dedicated Homebrew CVE pass. Add an NVD key for higher rate limits.",
  },
  {
    key: "updates", tone: "update", span: "lg", title: "Updates",
    body: "See which tools have a newer version waiting, then generate a script to update them all in one go.",
  },
  {
    key: "disk", tone: "accent", span: "sm", title: "Disk usage",
    body: "Measure what each tool actually costs on disk, and find the hogs.",
  },
  {
    key: "doctor", tone: "orphan", span: "sm", title: "Doctor",
    body: "Flags broken symlinks and PATH shadowing, two tools answering to the same name.",
  },
  {
    key: "deps", tone: "accent", span: "sm", title: "Dependency check",
    body: "Verifies the external tools catalog itself relies on are present.",
  },
];
---
<section class="section audits">
  <div class="container">
    <div class="audits-intro r-up">
      <h2>Audits, built in.</h2>
      <p class="lede">Beyond listing what you have, catalog checks it: what's vulnerable, what's out of
        date, and what's quietly wasting space.</p>
    </div>
    <div class="audits-bento">
      {audits.map((a) => (
        <article class={`audit audit-${a.span} r-up`} data-tone={a.tone}>
          <span class="audit-icon" aria-hidden="true">
            {a.key === "cve" && (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3 4 6v6c0 4.5 3.2 7.3 8 9 4.8-1.7 8-4.5 8-9V6z"/><path d="M12 9v4"/><path d="M12 16h.01"/></svg>
            )}
            {a.key === "updates" && (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20V7"/><path d="M6 11l6-6 6 6"/><path d="M5 20h14"/></svg>
            )}
            {a.key === "disk" && (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="6" width="18" height="12" rx="2"/><path d="M6 12h6"/><circle cx="16.5" cy="12" r="1.3" fill="currentColor" stroke="none"/></svg>
            )}
            {a.key === "doctor" && (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M9 4v5a5 5 0 0 0 6 0V4"/><path d="M12 14v3a3 3 0 0 0 6 0v-1"/><circle cx="18" cy="15" r="1.6"/></svg>
            )}
            {a.key === "deps" && (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M9 12a3 3 0 0 1 3-3h2a3 3 0 0 1 0 6h-1"/><path d="M15 12a3 3 0 0 1-3 3h-2a3 3 0 0 1 0-6h1"/></svg>
            )}
          </span>
          <h3>{a.title}</h3>
          <p>{a.body}</p>
        </article>
      ))}
    </div>
  </div>
</section>
<style>
  .audits-intro { max-width: 46ch; margin-bottom: clamp(36px, 5vw, 56px); }
  .audits-intro .lede { margin-top: 18px; }
  .audits-bento { display: grid; grid-template-columns: repeat(6, 1fr); grid-auto-flow: dense; gap: 1px;
    background: var(--line); border: 1px solid var(--line); border-radius: var(--radius-lg); overflow: hidden; }
  .audit { background: var(--bg); padding: clamp(22px, 2.6vw, 34px); grid-column: span 6;
    transition: background-color .3s ease; }
  .audit:hover { background: var(--surface); }
  .audit-icon svg { width: 26px; height: 26px; }
  .audit[data-tone="danger"] .audit-icon { color: var(--danger); }
  .audit[data-tone="update"] .audit-icon { color: var(--update); }
  .audit[data-tone="orphan"] .audit-icon { color: var(--orphan); }
  .audit[data-tone="accent"] .audit-icon { color: var(--accent); }
  .audit h3 { margin: 16px 0 8px; font-size: 1.15rem; }
  .audit p { margin: 0; color: var(--text-2); max-width: 44ch; }
  @media (min-width: 860px) {
    .audit-lg { grid-column: span 3; }
    .audit-sm { grid-column: span 2; }
  }
</style>
