---
// Copy + visual, alternating sides. Visual goes in the default slot.
interface Props {
  title: string;
  body: string;
  highlights: { label: string; desc: string }[];
  reverse?: boolean;
}
const { title, body, highlights, reverse = false } = Astro.props;
---
<section class={`section feat ${reverse ? "feat-rev" : ""}`}>
  <div class="container feat-grid">
    <div class="feat-copy r-up">
      <h2><slot name="title">{title}</slot></h2>
      <p class="lede">{body}</p>
      <ul class="feat-list">
        {highlights.map((h) => (
          <li>
            <span class="feat-dot" aria-hidden="true"></span>
            <span><b>{h.label}</b> {h.desc}</span>
          </li>
        ))}
      </ul>
    </div>
    <div class="feat-visual r-up"><slot /></div>
  </div>
</section>
<style>
  .feat-grid { display: grid; grid-template-columns: 1fr; gap: clamp(36px, 6vw, 64px); align-items: center; }
  @media (min-width: 900px) {
    .feat-grid { grid-template-columns: 1fr 1fr; }
    .feat-rev .feat-copy { order: 2; }
  }
  .feat-copy .lede { margin: 18px 0 28px; }
  .feat-list { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 15px; }
  .feat-list li { display: flex; gap: 12px; align-items: flex-start; }
  .feat-dot { width: 7px; height: 7px; border-radius: 999px; background: var(--accent); margin-top: 8px; flex: 0 0 auto; }
  .feat-list span span, .feat-list li > span:last-child { color: var(--text-2); }
  .feat-list b { color: var(--text); font-weight: 600; }
</style>
