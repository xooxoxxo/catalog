---
// The real Catalog owl (site/public/owl.svg), recolored to currentColor via a
// CSS mask so it tints to Voltage and stays light. Reveal is fade+scale (the
// asset is filled, not stroked, so no self-draw).
interface Props { size?: number; class?: string; }
const { size = 64, class: cls } = Astro.props;
---
<span class:list={["owlmark", cls]} style={`--owl-size:${size}px`} role="img" aria-label="Catalog"></span>
<style>
  .owlmark { display: inline-block; width: var(--owl-size); height: var(--owl-size);
    background: currentColor; flex: 0 0 auto;
    -webkit-mask: url("/owl.svg") no-repeat center / contain;
    mask: url("/owl.svg") no-repeat center / contain; }
</style>
