---
const pillars = [
  {
    title: "Catalog everything",
    body: "Catalog scans brew, cargo, npm, pipx and more, then folds every binary into one searchable list. Each forgotten tool gets an AI-written description and tags, so you finally know what it is and why it's there.",
  },
  {
    title: "Stay safe and current",
    body: "It checks your installed versions against known CVEs, flags every tool with an update waiting, and runs a doctor for broken symlinks and binaries shadowed on your PATH.",
  },
  {
    title: "Built for the keyboard",
    body: "Jump to anything from a ⌘K palette, filter hundreds of tools as you type, and reshape the whole UI to your taste. Fast by default, quiet until you need it.",
  },
];
const leadSources = ["brew", "cargo", "npm", "pipx"];
---
<section class="section pillars">
  <div class="container">
    <div class="pillars-bento">
      <article class="pillar pillar-lead reveal">
        <span class="pillar-n mono">01</span>
        <h3>{pillars[0].title}</h3>
        <p>{pillars[0].body}</p>
        <div class="pillar-sources" aria-hidden="true">
          {leadSources.map((s) => <span class="src-chip mono">{s}</span>)}
          <span class="src-chip mono more">+more</span>
        </div>
      </article>
      <article class="pillar reveal">
        <span class="pillar-n mono">02</span>
        <h3>{pillars[1].title}</h3>
        <p>{pillars[1].body}</p>
      </article>
      <article class="pillar reveal">
        <span class="pillar-n mono">03</span>
        <h3>{pillars[2].title}</h3>
        <p>{pillars[2].body}</p>
      </article>
    </div>
  </div>
</section>
<style>
  .pillars-bento { display: grid; grid-template-columns: repeat(6, 1fr); grid-auto-flow: dense;
    gap: 1px; background: var(--line); border: 1px solid var(--line);
    border-radius: var(--radius-lg); overflow: hidden; }
  .pillar { background: var(--bg); padding: clamp(24px, 3vw, 40px); display: flex; flex-direction: column;
    grid-column: span 6; transition: background-color .3s ease; }
  .pillar:hover { background: var(--surface); }
  .pillar-n { color: var(--accent); font-size: 0.8rem; }
  .pillar h3 { margin: 16px 0 10px; }
  .pillar p { color: var(--text-2); margin: 0; max-width: 46ch; }
  .pillar-lead h3 { font-size: clamp(1.4rem, 2.2vw, 1.9rem); }
  .pillar-sources { display: flex; flex-wrap: wrap; gap: 7px; margin-top: auto; padding-top: 28px; }
  .src-chip { font-size: 11px; color: var(--text-3); background: var(--surface2);
    border: 1px solid var(--line2); border-radius: var(--radius-sm); padding: 3px 9px; }
  .src-chip.more { color: var(--accent); border-color: color-mix(in srgb, var(--accent) 40%, transparent); }
  @media (min-width: 820px) {
    .pillars-bento { grid-template-rows: repeat(2, 1fr); }
    .pillar-lead { grid-column: 1 / span 3; grid-row: 1 / span 2; }
    .pillar:nth-child(2) { grid-column: 4 / span 3; grid-row: 1; }
    .pillar:nth-child(3) { grid-column: 4 / span 3; grid-row: 2; }
  }
</style>
